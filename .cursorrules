{
  "name": "7 Законов Успеха — Правила разработки",
  "version": "1.0",
  "description": "Стратегические правила для построения проектов. Основаны на 2500 лет исследований.",
  
  "laws": {
    "1_compound": {
      "name": "Compound Effect",
      "rule": "Каждое изменение должно быть маленьким, но улучшать продукт. 1% в день = 38x за год. Никаких больших переписываний — только итерации.",
      "implementation": [
        "Каждый коммит = одно улучшение",
        "Каждый PR = одна функция",
        "Рефакторинг — постоянно, по чуть-чуть",
        "Тесты добавляй инкрементально"
      ]
    },
    "2_focus": {
      "name": "Фокус",
      "rule": "Одна задача за раз. Не начинай новое, пока не закончил текущее. Концепция Ежа Collins: делай ОДНО, но лучше всех.",
      "implementation": [
        "1 фича за спринт",
        "MVP = минимум функций, максимум качества",
        "Убирай лишнее безжалостно",
        "Если функция не решает главную боль — не делай"
      ]
    },
    "3_feedback": {
      "name": "Обратная связь",
      "rule": "OODA Loop: Наблюдай → Оценивай → Решай → Действуй. Быстрее цикл = быстрее победа.",
      "implementation": [
        "Деплой каждый день",
        "Аналитика с первого дня",
        "Метрики: retention, activation, NPS",
        "Sean Ellis Test: 40%+ 'очень расстроен' = PMF",
        "Спрашивай пользователей каждую неделю"
      ]
    },
    "4_antifragile": {
      "name": "Антихрупкость",
      "rule": "Система должна становиться лучше от стресса. Барбелл: 80% стабильного + 20% экспериментов.",
      "implementation": [
        "Graceful degradation — падение части не убивает всё",
        "Feature flags для экспериментов",
        "A/B тесты перед полным запуском",
        "Резервные копии, fallback, retry",
        "Ошибки = данные для улучшения"
      ]
    },
    "5_first_principles": {
      "name": "Первые принципы",
      "rule": "Не копируй решения. Спроси: какую проблему я решаю? Что точно правда? Как бы я сделал с нуля?",
      "implementation": [
        "Перед каждой фичей: зачем? для кого? какая боль?",
        "JTBD: какую 'работу' клиент 'нанимает' продукт?",
        "Инверсия Мангера: что ГАРАНТИРОВАННО сделает продукт хуже?",
        "Не добавляй технологию ради технологии"
      ]
    },
    "6_network": {
      "name": "Сеть и связи",
      "rule": "Встрой сетевые эффекты. Продукт должен становиться лучше с каждым пользователем.",
      "implementation": [
        "Вирусные механики: приглашения, шеринг, коллаборация",
        "User-generated content",
        "Интеграции и API",
        "Сообщество вокруг продукта"
      ]
    },
    "7_system": {
      "name": "Система",
      "rule": "Продукт = система. Ищи точки рычага. Маховик Collins: тысячи маленьких шагов в одном направлении.",
      "implementation": [
        "Flywheel: каждое действие усиливает следующее",
        "Hook-цикл: Триггер → Действие → Награда → Инвестиция",
        "Switching costs растут с использованием (IKEA effect)",
        "Экосистема > отдельный продукт"
      ]
    }
  },

  "design_rules": {
    "visual": {
      "theme": "Тёмная тема по умолчанию с переключением",
      "typography": "Крупные заголовки 32-48px, sans-serif (Inter, system-ui)",
      "colors": "Максимум 3: 1 акцент (фиолетовый/синий) + 2 нейтральных",
      "spacing": "Много воздуха. Padding 1.5-2rem в карточках",
      "cards": "border-radius 12-16px, subtle border, hover effect",
      "animations": "150-300ms, ease-out. Fade-up при появлении. Без декора"
    },
    "ux": {
      "time_to_value": "< 60 секунд от первого визита до ценности",
      "simplicity": "1 экран = 1 действие. Убирай лишнее",
      "mobile_first": "Адаптивный дизайн обязателен",
      "accessibility": "Контраст AA+, размер шрифта от 16px"
    },
    "copy": {
      "headlines": "Заголовок = вывод, не тема. Пиши как инсайт",
      "language": "Простые слова. Если 5-летний не поймёт — перепиши",
      "cta": "Глагол + результат + снижение риска"
    }
  },

  "landing_structure": {
    "sections": [
      {"name": "Hero", "hormone": "Дофамин", "goal": "Обещание результата + CTA"},
      {"name": "Проблема", "hormone": "Кортизол", "goal": "Усилить боль, показать потери"},
      {"name": "Решение", "hormone": "Эндорфины", "goal": "Облегчение, надежда"},
      {"name": "Как работает", "hormone": "Дофамин", "goal": "3-5 шагов, простота"},
      {"name": "Преимущества", "hormone": "Серотонин", "goal": "Каким ты станешь"},
      {"name": "Доказательства", "hormone": "Окситоцин", "goal": "Отзывы, кейсы, цифры"},
      {"name": "Цена/CTA", "hormone": "Адреналин", "goal": "Срочность + гарантия"},
      {"name": "FAQ", "hormone": "Эндорфины", "goal": "Снять последние страхи"},
      {"name": "Финальный CTA", "hormone": "Адреналин + Дофамин", "goal": "Последний толчок"}
    ]
  },

  "metrics": {
    "pmf": "Sean Ellis Test >= 40% 'очень расстроен'",
    "activation": "> 40% новых пользователей выполняют ключевое действие",
    "retention_d1": "> 40%",
    "retention_d7": "> 20%",
    "retention_d30": "> 10%",
    "ltv_cac_ratio": "> 3x",
    "time_to_value": "< 60 секунд",
    "nps": "> 50"
  },

  "gtm_2026": {
    "model": "Outcome as a Service — продавай результат, не подписку",
    "acquisition": "Product-Led Growth: продукт = канал роста",
    "trust": "Value-first: дай ценность бесплатно → получи доверие",
    "ai": "AI-агенты для автоматизации поддержки, онбординга, персонализации"
  }
}
